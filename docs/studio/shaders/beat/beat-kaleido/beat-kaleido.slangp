shaders = 1

shader0        = beat-kaleido.slang
filter_linear0 = true
scale_type0    = source
scale0         = 1.0
wrap_mode0     = clamp_to_edge

parameters = "amount;bpm;fps;beat_div;segments;spin;beat_kick;zoom_pulse;pulse_decay"
